<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="FeedbackButtonStyle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_height">40dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="CorrectButtonStyle" parent="FeedbackButtonStyle">
        <item name="strokeColor">#4CAF50</item>
        <item name="android:textColor">#4CAF50</item>
    </style>

    <style name="WrongButtonStyle" parent="FeedbackButtonStyle">
        <item name="strokeColor">#F44336</item>
        <item name="android:textColor">#F44336</item>
    </style>
</resources>